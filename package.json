{
  "name": "@ikenga/cli",
  "version": "0.0.0",
  "description": "Command-line tool for installing, updating, and managing Ikenga pkgs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/royalti-io/ikenga-cli.git"
  },
  "type": "module",
  "bin": {
    "ikenga": "./dist/ikenga"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --compile --outfile ./dist/ikenga --target bun",
    "dev": "bun run ./src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ikenga/contract": "workspace:*",
    "@ikenga/registry-client": "^0.1.0",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/tar": "^6.1.13",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
